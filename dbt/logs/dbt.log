    sk_funcionario,
    sk_data,
    count(*)    as ocorrencias

from "db_dw"."marts"."fato_ponto"

group by sk_funcionario, sk_data

having count(*) > 1

-- Se esta query retornar QUALQUER linha, o teste falha.
-- Esperado: 0 linhas (cada combinação funcionário+dia deve ser única)
  
  
      
    ) dbt_internal_test
